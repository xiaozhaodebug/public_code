# =============================================================================
# Embedded C/C++ GitIgnore
# 适用于: ARM Cortex-M (STM32, NXP S32K) 项目
# =============================================================================

# -----------------------------------------------------------------------------
# 编译输出文件 / Build Outputs
# -----------------------------------------------------------------------------
# 对象文件
*.o
*.obj
*.elf
*.axf

# 可执行文件/二进制文件
*.exe
*.bin
*.hex
*.srec
*.mot

# 库文件
*.a
*.lib
*.la
*.lo
*.so
*.dll

# 映射文件和列表文件
*.map
*.lst
*.list

# 依赖文件
*.d
*.dep

# -----------------------------------------------------------------------------
# IDE 特定文件 / IDE Specific
# -----------------------------------------------------------------------------

# Keil MDK
*.uvguix.*
*.uvoptx
*.uvprojx.bak
*.uvoptx.bak
*.scvd
JLinkLog.txt
JLinkSettings.ini
DebugConfig/
RTE/

# NXP S32 Design Studio
*.launch
.settings/
.project.bak
.cproject.bak

# Eclipse
.metadata/
RemoteSystemsTempFiles/

# VS Code (可选)
# .vscode/

# -----------------------------------------------------------------------------
# 编译目录 / Build Directories
# -----------------------------------------------------------------------------
# 通用输出目录
build/
Build/
BUILD/
out/
Out/
OUT/

# Keil 输出目录
Objects/
OBJ/
obj/
List/
LIST/
list/

# NXP S32DS 输出目录
Debug_FLASH/
Debug_RAM/
Release/

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile.cmake

# -----------------------------------------------------------------------------
# 调试文件 / Debug Files
# -----------------------------------------------------------------------------
*.log
*.trc
*.dbg

# -----------------------------------------------------------------------------
# 临时文件 / Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
.*.swp
.*.swo

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# 自动生成的文件 / Auto-generated
# -----------------------------------------------------------------------------
# 如果 Generated_Code 是工具生成的且不需要版本控制，可以取消注释
# Generated_Code/
# Generated/

# -----------------------------------------------------------------------------
# 敏感信息 / Sensitive (示例)
# -----------------------------------------------------------------------------
# secrets.h
# config_private.h
# *.key
# *.pem
